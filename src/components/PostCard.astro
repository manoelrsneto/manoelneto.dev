---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    slug: string;
    tags?: string[];
    index?: number;
}

const { title, description, pubDate, slug, tags, index = 1 } = Astro.props;

const dateStr = pubDate.toISOString().split("T")[0];
const fileName = `${slug.split("/").at(-1) ?? slug}.mdx`;
const itemNumber = String(index).padStart(2, "0");
---

<article class="group">
    <a
        href={`/blog/${slug}`}
        aria-label={`Open post: ${title}`}
        class="block rounded-md border border-transparent px-0 py-4 transition-colors hover:border-[var(--color-border)] hover:bg-[var(--color-status-bg)]/45 sm:px-3"
    >
        <div
            class="grid grid-cols-[2.5rem_minmax(0,1fr)_auto] items-baseline gap-3"
        >
            <span
                class="font-mono text-xs font-bold text-[var(--color-overlay)] group-hover:text-[var(--color-blue)]"
            >
                {itemNumber}
            </span>
            <h2
                class="min-w-0 font-mono text-base font-bold leading-tight text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)]"
            >
                <span
                    class="status-icon mr-1 text-xs text-[var(--color-overlay)] transition-colors group-hover:text-[var(--color-red)]"
                    >󰈙</span
                >
                <span>{fileName}</span>
            </h2>
            <time
                datetime={pubDate.toISOString()}
                class="hidden shrink-0 font-mono text-xs font-bold text-[var(--color-overlay)] sm:block"
            >
                {dateStr}
            </time>
        </div>

        <p
            class="mt-1 pl-[3.25rem] text-sm leading-relaxed text-[var(--color-subtext)]"
        >
            {description}
        </p>

        {
            tags && tags.length > 0 && (
                <div class="mt-3 flex flex-wrap gap-2 pl-[3.25rem]">
                    {tags.map((tag) => (
                        <span class="status-group">
                            <span class="status-segment status-muted">
                                #{tag}
                            </span>
                        </span>
                    ))}
                </div>
            )
        }
    </a>
</article>
