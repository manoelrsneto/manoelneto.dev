---
interface Props {
    title: string;
    description: string;
    pubDate: Date;
    slug: string;
    tags?: string[];
    index?: number;
}

const { title, description, pubDate, slug, tags } = Astro.props;

const dateStr = pubDate.toISOString().split("T")[0];
const fileName = `${slug.split("/").at(-1) ?? slug}.mdx`;
const firstTag = tags?.[0];
const extraTags = tags?.slice(1) ?? [];
---

<article class="group">
    <a
        href={`/blog/${slug}`}
        aria-label={`Open post: ${title}`}
        class="block rounded-md border border-transparent px-0 py-4 transition-colors hover:border-[var(--color-border)] hover:bg-[var(--color-status-bg)]/45 sm:px-3"
    >
        <!-- Prompt context line (Starship-style) -->
        <div
            class="mb-2 flex flex-wrap items-center gap-x-2 gap-y-1 font-mono text-xs font-bold"
        >
            <!-- Directory -->
            <span class="flex items-center gap-1 text-[var(--color-teal)]">
                <span class="status-icon"></span>
                <span>~/blog</span>
            </span>

            <!-- Git-style branch from first tag -->
            {
                firstTag && (
                    <>
                        <span class="text-[var(--color-overlay)]">on</span>
                        <span class="flex items-center gap-1 text-[var(--color-mauve)]">
                            <span class="status-icon" />
                            <span>{firstTag}</span>
                        </span>
                    </>
                )
            }

            <!-- Extra tags as dirty-status markers -->
            {
                extraTags.length > 0 && (
                    <span class="text-[var(--color-yellow)]">
                        [{extraTags.map((t) => `+${t}`).join(" ")}]
                    </span>
                )
            }

            <!-- Date pushed to the right -->
            <time
                datetime={pubDate.toISOString()}
                class="ml-auto shrink-0 text-[var(--color-overlay)]"
            >
                {dateStr}
            </time>
        </div>

        <!-- Cursor + filename line -->
        <div class="mb-1 flex items-center gap-2 font-mono text-sm font-bold">
            <span
                class="shrink-0 text-[var(--color-blue)] transition-colors group-hover:text-[var(--color-accent)]"
                >❯</span
            >
            <span class="flex min-w-0 items-center gap-1.5">
                <span
                    class="status-icon shrink-0 text-xs text-[var(--color-overlay)]"
                    >󰈙</span
                >
                <span
                    class="truncate text-[var(--color-text)] transition-colors group-hover:text-[var(--color-accent)]"
                    >{fileName}</span
                >
            </span>
        </div>

        <!-- Human title (like a command output header) -->
        <p
            class="mb-1 pl-5 font-mono text-xs font-bold text-[var(--color-overlay)]"
        >
            # {title}
        </p>

        <!-- Description -->
        <p class="pl-5 text-sm leading-relaxed text-[var(--color-subtext)]">
            {description}
        </p>
    </a>
</article>
