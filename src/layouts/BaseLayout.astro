---
import Header from "@/components/Header.astro";
import CommandPalette from "@/components/CommandPalette.astro";
import Footer from "@/components/Footer.astro";
import SearchPalette from "@/components/SearchPalette.astro";
import { ui } from "@/i18n/ui";
import "@/styles/global.css";

interface Props {
    title: string;
    description?: string;
    ogImage?: string;
    pageLang?: "en" | "pt";
    translationSlug?: string;
    localeSwitchHref?: string;
}

const {
    title,
    description = ui.en.siteDescription,
    ogImage = new URL("/og-default.svg", Astro.site).toString(),
    pageLang = "en",
    translationSlug,
    localeSwitchHref,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const uiText = ui[pageLang];
const homeHref = pageLang === "pt" ? "/pt" : "/";
---

<!doctype html>
<html lang={pageLang}>
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="view-transition" content="same-origin" />
        <link rel="canonical" href={canonicalURL} />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:type" content="website" />
        <meta property="og:image" content={ogImage} />
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={title} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />
        <link
            rel="alternate"
            type="application/rss+xml"
            title={uiText.rssTitle}
            href={new URL(uiText.rssHref, Astro.site)}
        />
        <script is:inline>
            (function () {
                const stored = localStorage.getItem("theme");
                const prefersDark = window.matchMedia(
                    "(prefers-color-scheme: dark)",
                ).matches;
                if (stored === "dark" || (!stored && prefersDark)) {
                    document.documentElement.classList.add("dark");
                }
            })();
        </script>
        <script is:inline>
            (function () {
                if (window.location.pathname !== "/") return;
                if (localStorage.getItem("lang-pref")) return;
                var lang = (navigator.language || "").toLowerCase();
                if (lang.startsWith("pt")) {
                    window.location.replace("/pt");
                }
            })();
        </script>

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    </head>
    <body
        data-page-lang={pageLang}
        data-home-href={homeHref}
        data-locale-switch-href={localeSwitchHref}
    >
        <Header pageLang={pageLang} localeSwitchHref={localeSwitchHref} />
        <main
            class="max-w-2xl mx-auto px-6 py-10 pb-14 sm:pb-16 flex-1"
            data-pagefind-body
        >
            <slot />
        </main>
        <Footer pageLang={pageLang} translationSlug={translationSlug} />
        <SearchPalette pageLang={pageLang} />
        <CommandPalette />
    </body>
</html>
