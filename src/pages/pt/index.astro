---
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { ui } from "@/i18n/ui";
import { getCollection } from "astro:content";

const allPosts = await getCollection(
    "posts",
    ({ data }) => !data.draft && data.lang === "pt",
);
const posts = allPosts.sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const uiText = ui.pt;
---

<BaseLayout
    title="manoelneto.dev"
    description={uiText.homeDescription}
    pageLang="pt"
    localeSwitchHref="/"
>
    <section>
        <div class="mb-10 font-mono">
            <div
                class="mb-3 flex items-center gap-2 text-sm font-bold text-[var(--color-overlay)]"
            >
                <span class="text-[var(--color-blue)]">❯</span>
                <span>whoami</span>
            </div>
            <p class="mb-5 text-sm leading-relaxed text-[var(--color-subtext)]">
                <span class="font-bold text-[var(--color-text)]">Manoel</span> — {
                    uiText.whoami
                }
            </p>

            <div
                class="mb-3 flex items-center gap-2 text-sm font-bold text-[var(--color-overlay)]"
            >
                <span class="text-[var(--color-blue)]">❯</span>
                <span>focus</span>
            </div>
            <p
                class="text-sm font-bold leading-relaxed text-[var(--color-subtext)]"
            >
                <span class="text-[var(--color-blue)]">{uiText.focus[0]}</span>
                <span class="text-[var(--color-overlay)]"> · </span>
                <span>{uiText.focus[1]}</span>
                <span class="text-[var(--color-overlay)]"> · </span>
                <span>{uiText.focus[2]}</span>
            </p>
        </div>

        <div class="editor-ruler mb-3" aria-hidden="true">
            <span></span>
            <strong>posts</strong>
            <em
                >{posts.length}
                {posts.length === 1 ? uiText.entry : uiText.entries} · sorted desc</em
            >
            <span></span>
        </div>

        <div class="post-list">
            {
                posts.map((post, index) => (
                    <PostCard
                        title={post.data.title}
                        description={post.data.description}
                        pubDate={post.data.pubDate}
                        slug={post.slug}
                        tags={post.data.tags}
                        index={index + 1}
                    />
                ))
            }

            {
                posts.length === 0 && (
                    <p class="py-8 text-center font-mono text-sm font-bold text-[var(--color-overlay)]">
                        {uiText.emptyPosts}
                    </p>
                )
            }
        </div>
    </section>
</BaseLayout>
